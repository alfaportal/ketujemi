{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd ketujemi-2 && pnpm install --no-frozen-lockfile",
  "buildCommand": "cd ketujemi-2 && pnpm --filter @workspace/vendi run build",
  "outputDirectory": "ketujemi-2/artifacts/vendi/dist/public",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://ketujemi-production.up.railway.app/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
