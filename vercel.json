{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "export NODE_OPTIONS=\"${NODE_OPTIONS:+$NODE_OPTIONS }--disable-warning=DEP0040\" && corepack enable && corepack prepare pnpm@10.12.1 --activate && pnpm config set minimum-release-age 0 && pnpm install --no-frozen-lockfile",
  "buildCommand": "export NODE_OPTIONS=\"${NODE_OPTIONS:+$NODE_OPTIONS }--disable-warning=DEP0040\" && pnpm run build",
  "outputDirectory": "ketujemi-2/artifacts/vendi/dist/public",
  "framework": null,
  "functions": {
    "api/handler.mjs": {
      "maxDuration": 60
    },
    "api/cron/jobs.mjs": {
      "maxDuration": 120
    }
  },
  "crons": [
    {
      "path": "/api/cron/jobs",
      "schedule": "0 * * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/handler"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
