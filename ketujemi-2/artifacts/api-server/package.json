{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node ./build.mjs",
    "build:vercel": "node ./build-vercel.mjs",
    "build:watch": "node ./build.mjs --watch",
    "dev": "node ./dev-watch.mjs",
    "dev:once": "pnpm run build && pnpm run start",
    "start": "node --enable-source-maps --env-file=../../.env ./dist/index.mjs",
    "run:facebook-scheduled-post": "tsx ./src/scripts/run-facebook-scheduled-post.ts",
    "run:social-scheduled-posts": "tsx ./src/scripts/run-social-scheduled-posts.ts",
    "run:listing-reel": "tsx ./src/scripts/run-listing-reel.ts",
    "typecheck": "tsc --build ../../lib/db/tsconfig.json ../../lib/api-zod/tsconfig.json && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@aws-sdk/client-s3": "^3.1050.0",
    "@aws-sdk/s3-request-presigner": "^3.1050.0",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "bcryptjs": "^3.0.3",
    "bull": "^4.16.5",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "express-rate-limit": "^8.5.2",
    "firebase-admin": "^13.10.0",
    "ioredis": "^5.11.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.6",
    "pino": "^9",
    "pino-http": "^10",
    "serverless-http": "^3.2.0",
    "stripe": "^22.1.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@types/nodemailer": "^7.0.1",
    "@vercel/node": "^5.0.0",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0",
    "tsx": "catalog:"
  }
}
