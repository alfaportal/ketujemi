# =============================================================================
# KetuJemi / Vendi — environment variables reference
#
# This repo does not load a single root `.env` for all packages. Set variables
# in your shell (see PowerShell examples at the bottom) or use a local `.env`
# where a tool supports it (e.g. Vite loads `VITE_*` from `artifacts/vendi`).
#
# IMPORTANT: The API and Vite both read `PORT` but must use different values
# on two separate terminals.
# =============================================================================

# --- Shared (API + Drizzle) ---
# Required. Used by @workspace/db and drizzle-kit (`lib/db`).
# Neon pooled URL — use ?sslmode=require only on Railway (no &channel_binding; ampersand breaks some hosts).
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.pooler.region.aws.neon.tech/neondb?sslmode=require"
DATABASE_URL=

# --- API server (`artifacts/api-server`) ---
# Required at runtime (preferred over PORT on Windows).
API_PORT=8080

# Production single-port deploy: API serves Vite build from this folder.
# STATIC_ROOT=artifacts/vendi/dist/public

# Public site URL (auth email links, Stripe return URLs). Set to your live domain in production.
# PUBLIC_APP_ORIGIN=https://your-app.example.com

# --- Phase 2 (TOP checkout €2/€5/€8, public payments when traffic grows) ---
# FEATURE_PHASE_2=false

# --- Pagesa: tani Stripe; më vonë bankë KS + fiskalizim ---
# Hapat (pas Enternet + llogarisë bankare biznes):
#   1) STRIPE_* — mbetet për diasporën / kartë ndërkombëtare
#   2) KOSOVO_BANK_PAYMENTS_ENABLED=true + IBAN + API bankës → përdorues +383 shkojnë te banka lokale
#   3) FISCAL_KOSOVO_ENABLED=true + Enternet API → kupon fiskal vetëm për pagesa bankë KS (jo Stripe)
#
# --- Stripe Checkout (VIP, TOP, portofol €5/€10/€20, njoftim shtesë) ---
# Wallet: €0.30 per paid listing; top-ups €5 (16), €10 (33), €20 (66 listings)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...
# Same key for Vite build (optional if API serves /api/config/public):
# VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe Dashboard → Developers → Webhooks → Add endpoint:
#   URL: https://ketujemi.com/api/payments/webhook  (or your Railway/Vercel domain)
#   Events: checkout.session.completed
# After deploy, run SQL migrations if not applied:
#   lib/db/sql/business-payments-migration.sql
#   lib/db/sql/partners-payment-automation-migration.sql
#   lib/db/sql/listing-package-purchases-migration.sql
#   lib/db/sql/wallet-migration.sql
#   lib/db/sql/fiscal-receipts-migration.sql
#   lib/db/sql/phone-verify-challenges-migration.sql
# Dev only: auto-mark checkout as paid when Stripe is not configured (non-production)
# PAYMENT_DEV_BYPASS=true

# Kosovo (+383): uses Stripe automatically when STRIPE_* keys exist (no extra flag needed).
# Local bank for wallet ONLY when Stripe is not configured AND this is true:
# KOSOVO_WALLET_USE_BANK=false
# --- Kosovo bank (portofol për +383) — off derisa të keni llogari merchant ---
# KOSOVO_BANK_PAYMENTS_ENABLED=false
# KOSOVO_BANK_NAME=Raiffeisen Bank Kosovo
# KOSOVO_BANK_IBAN=XK...
# KOSOVO_BANK_MERCHANT_ID=
# KOSOVO_BANK_API_URL=
# KOSOVO_BANK_BENEFICIARY=REVOLUTION INVEST Sh.p.k.
# Set true only after bank hosted API is wired in provider.ts
# KOSOVO_BANK_PROVIDER_READY=false

# --- Kosovo fiscal (vetëm pas bankës KS + Enternet) ---
# Stripe NUK lëshon faturë/kupon — vetëm pagesa përmes bankës KS kur të dyja janë ON.
# FISCAL_KOSOVO_ENABLED=false
# FISCAL_KOSOVO_PROVIDER=placeholder
# FISCAL_KOSOVO_API_URL=
# FISCAL_KOSOVO_API_KEY=
# FISCAL_LEGAL_NAME=REVOLUTION INVEST Sh.p.k.
# FISCAL_NRB=811314567
# FISCAL_CITY=Ferizaj
# FISCAL_VAT_PERCENT=18

# Optional. Default: info
# LOG_LEVEL=info

# --- Vite app (`artifacts/vendi`) ---
# Required for `pnpm run dev` (preferred over PORT on Windows).
WEB_PORT=5173
# Required. Use "/" for local dev.
# BASE_PATH=/

# Optional — dev proxy: browser calls /api → this backend (default http://127.0.0.1:8080)
# API_PROXY_TARGET=http://127.0.0.1:8080

# --- Transactional email (contact form, regjistrim, partner, rikujtues njoftimesh) ---
# REQUIRED on production — pa këto, email-et NUK dërgohen.
#
# Opsioni A (rekomandohet): Resend — https://resend.com → API Keys + verify domain ketujemi.com
RESEND_API_KEY=
EMAIL_FROM=KetuJemi <noreply@ketujemi.com>
#
# Opsioni B: SMTP (Gmail app password, etj.) — përdoret së pari nëse EMAIL_USER/PASS janë vendosur
# EMAIL_USER=
# EMAIL_PASS=
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
#
# Inbox për formularin /kontakt (default info@ketujemi.com)
# CONTACT_INBOX=info@ketujemi.com
# Email sign-up verification (on by default). false = regjistrim pa kod email
# EMAIL_VERIFICATION_REQUIRED=true
# Admin alerts + daily monitor report (foto, duplikate, health)
EMAIL_ADMIN=
# Admin security alerts (failed login / brute-force) — email to EMAIL_ADMIN; optional SMS:
# ADMIN_ALERT_PHONE=3834xxxxxxx

# --- Monitorim automatik 24/7 (API server) ---
# MONITOR_ENABLED=true
# MONITOR_INTERVAL_MS=600000
# MONITOR_DAILY_HOUR=8
# MONITOR_TIMEZONE=Europe/Tirane
# MONITOR_ALERT_COOLDOWN_MS=3600000

# --- Google reCAPTCHA v2 (SMS «Nuk jam robot») ---
# Create keys: https://www.google.com/recaptcha/admin (reCAPTCHA v2 → "I'm not a robot")
# Site key → Railway Variables (used at Vite build AND runtime via /api/config/public)
# VITE_RECAPTCHA_SITE_KEY=
# Secret key → API only (required to enforce captcha on POST /auth/sms/start)
# RECAPTCHA_SECRET_KEY=

# --- Auth (`artifacts/api-server`) — Vonage Verify + signed session cookie ---
# SESSION_SECRET: min 16 chars — MOS e ndrysho pas deploy-it (ndryshe çdo kyçje skadon)
SESSION_SECRET=
# Opsionale: cookie për www + ketujemi.com (default prod: .ketujemi.com)
# COOKIE_DOMAIN=.ketujemi.com

# --- Google Sign-In (OAuth 2.0) ---
# Google Cloud Console → APIs & Services → Credentials → OAuth client (Web)
# Authorized redirect URI (production): https://ketujemi.com/auth/google/callback
# Local dev (Vite proxy): http://localhost:5173/auth/google/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_OAUTH_ENABLED=true

# --- TikTok Login Kit ---
# TikTok Developer Portal → app → Login Kit → Redirect URI (production):
#   https://ketujemi.com/auth/tiktok/callback
# Local dev (Vite proxy): http://localhost:5173/auth/tiktok/callback
# TIKTOK_CLIENT_KEY=
# TIKTOK_CLIENT_SECRET=
# TIKTOK_OAUTH_ENABLED=true

# --- Facebook OAuth (Meta Developers app — KetuJemi.com / @jemi.ketu) ---
# Krijo app: https://developers.facebook.com/ → shto Facebook Login
# Butoni "Hyr me Facebook / Instagram" përdor të njëjtin flow Facebook OAuth.
# Valid OAuth Redirect URIs (prod):
#   https://ketujemi.com/api/auth/facebook/callback
# Local dev (Vite proxy): http://localhost:5173/api/auth/facebook/callback
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=
# FACEBOOK_OAUTH_ENABLED=true
# Footer Facebook (kopjo nga Meta → Faqja → Shiko si vizitor → URL në shfletues)
# FACEBOOK_PAGE_URL=https://www.facebook.com/USERNAME_I_SAKTE
# ose: FACEBOOK_PAGE_ID=123456789012345
# INSTAGRAM_PROFILE_URL=https://www.instagram.com/jemi.ketu

# Phone sign-up/login (Vonage Verify + SMS). Default off — use email.
# SMS_AUTH_ENABLED=false
# Vonage Dashboard → API Settings → API Key + API Secret (mos i commit në git)
# VONAGE_API_KEY=
# VONAGE_API_SECRET=
# Emri i dërguesit për SMS transaksional (duhet i aprovuar në Vonage)
# VONAGE_SMS_FROM=KetuJemi
# Emri i shfaqur në SMS-in e kodit OTP (Verify)
# VONAGE_VERIFY_BRAND=KetuJemi
# Heq TWILIO_* nga Railway nëse kalove plotësisht te Vonage.
# SMS anti-abuse (defaults shown)
# SMS only for +383/+355/+389/+382 unless SMS_ALLOW_INTERNATIONAL=true
# SMS_COOLDOWN_SECONDS=60
# SMS_MAX_PER_PHONE_DAY=3
# SMS_MAX_PER_IP_HOUR=5
# SMS_MAX_PER_IP_DAY=15

# --- Listing post: pause between posts for the same account (double-click / accidental repeats) ---
# LISTING_POST_USER_COOLDOWN_SECONDS=30
# Legacy alias (still read if USER var is unset): LISTING_POST_IP_COOLDOWN_SECONDS=30

# --- Backblaze B2 — foto njoftimesh (API kompatibl me S3). Nëse janë të gjitha të vendosura, përdoret B2 në vend të Cloudinary.
# Bucket: aktivizo leximin publik për skedarët (ose përdor CDN). CORS: lejo PUT nga origjina e faqes (dev + prod).
# Endpoint & rajon nga Backblaze → Bucket → «S3 Compatible API»
# B2_S3_ENDPOINT=https://s3.eu-central-003.backblazeb2.com
# B2_S3_REGION=eu-central-003
# B2_APPLICATION_KEY_ID=
# B2_APPLICATION_KEY=
# B2_BUCKET_NAME=
# URL bazë për shikim publik (shembull «Friendly URL» në konsolën B2): pa slash në fund
# B2_PUBLIC_URL_BASE=https://f005.backblazeb2.com/file/emri-i-bucket-it
# Opsionale — parashtesë për çelësat e objekteve:
# B2_KEY_PREFIX=listings

# --- Owner-only admin panel (`/admin`) — never commit real values ---
# ADMIN_PANEL_PASSWORD = fjalëkalimi që fut në telefon/kompjuter (ruaje në Bitwarden / letër të sigurt)
# ADMIN_PANEL_TOKEN    = sekret i gjatë (min 16 shkronja, më mirë 32+) për nënshkrimin e sesioneve — MOS e ndaj
ADMIN_PANEL_PASSWORD=
ADMIN_PANEL_TOKEN=
# Support chat («Ndihmë») — OPTIONAL; default +383 43 555 294 is in code (support-contact.ts)
# SUPPORT_PHONE=+38343555294

# Vercel cron (/api/cron/jobs) — set in Vercel dashboard; Vercel sends Authorization: Bearer <value>
# CRON_SECRET=generate-a-long-random-string

# Claude AI — moderation, posting assistant, recommendations, support chat (Railway Variables)
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-5

# Optional: Railway CLI token for `pnpm run railway:env:vonage` (never commit a real token)
# RAILWAY_TOKEN=
# --- Google Analytics 4 (vizitorë, faqe, vendndodhje në GA dashboard) ---
# Krijo pronë në https://analytics.google.com → Admin → Data streams → Web → kopjo Measurement ID (G-...)
# Vendos në Railway **para** build-it (si të gjitha VITE_*):
# VITE_GA_MEASUREMENT_ID=G-A396094792
# Raporte: Reports → Engagement → Pages; Reports → User → Demographics → Country/City

# --- Facebook Page auto-post (Meta Graph API) — new listings + scheduled cron ---
# Create at developers.facebook.com → Page access token with pages_manage_posts
# Set on Railway (never commit real tokens):
# FACEBOOK_APP_ID=           (same Meta app as login — used to exchange tokens at startup)
# FACEBOOK_APP_SECRET=       (never commit; rotate if exposed)
# FB_PAGE_ID=1112756445260808        (or PAGE_ID / FACEBOOK_PAGE_ID — Ketu Jemi page)
# FB_PAGE_ACCESS_TOKEN=              (or PAGE_ACCESS_TOKEN — needs pages_manage_posts + instagram_content_publish)
# INSTAGRAM_BUSINESS_ACCOUNT_ID=     (optional — auto-resolved from linked @ketujemi.ks IG account on the Page)
# INSTAGRAM_AUTO_POST_ENABLED=true   (separate IG cron — not simultaneous with Facebook)
# FB_SCHEDULED_POST_ENABLED=true     (Facebook: 10:00, 14:00, 19:00, 22:00 Europe/Belgrade)
# Instagram cron: 10:30, 14:30, 19:30, 22:30 (30 min after FB, different caption)
# Manual run with Railway vars (not local PAGE_ACCESS_TOKEN):
#   pnpm run run:social-scheduled-posts:railway
# Or POST https://ketujemi.com/api/cron/social-scheduled-posts with Authorization: Bearer <CRON_SECRET>
# FB_CRON_TZ=Europe/Belgrade         (optional timezone for both FB + IG cron)
# IG_CRON_TZ=Europe/Belgrade         (optional Instagram-only timezone override)

# --- Social followers tracking (admin /admin/followers) ---
# SOCIAL_FOLLOWERS_SYNC_ENABLED=true   (daily 06:00 Europe/Belgrade — Instagram follower count + list if API allows)
# SOCIAL_FOLLOWERS_CRON_TZ=Europe/Belgrade
# Individual follower usernames: import Instagram «Download your information» JSON in admin (Meta API gives count only).

# --- Listing Reel slideshow (Cloudinary video + Instagram Reels + TikTok) ---
# Requires CLOUDINARY_API_KEY + CLOUDINARY_API_SECRET (signed Admin API for create_slideshow).
# LISTING_REEL_CRON_ENABLED=true   (daily 12:00 Europe/Belgrade — 5 listings, 2.5s/slide, brand overlays)
# LISTING_REEL_CRON_TZ=Europe/Belgrade
# TIKTOK_AUTO_POST_ENABLED=true
# TIKTOK_CONTENT_ACCESS_TOKEN=     (TikTok Content Posting API — video.publish scope for @ketujemi7)

# Cloudinary unsigned upload — përdoret vetëm nëse B2 nuk është konfiguruar plotësisht.
# VITE_CLOUDINARY_CLOUD_NAME=ddwebeeek
# VITE_CLOUDINARY_UPLOAD_PRESET=ketujemi_upload
# Preset duhet të lejojë `folder` nga klienti.
# 1) listings/     — foto shpalljesh (fshihen kur shpallja fshihet ose pas 90 ditëve)
# 2) partners/     — logo/banner partnerësh (kurrë nuk fshihen automatikisht)
# 3) site-assets/  — banera, kategori, UI statik (kurrë nuk fshihen automatikisht)
# Për fshirje automatike të fotove të shpalljeve në Cloudinary (API server):
# CLOUDINARY_CLOUD_NAME=   # opsionale nëse tashmë keni VITE_CLOUDINARY_CLOUD_NAME
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# --- Usually unset on local Windows ---
# NODE_ENV    — set by tooling (development / production)
# REPL_ID     — set on Replit only; enables Replit-specific Vite plugins

# =============================================================================
# PowerShell examples (after `pnpm install` in this folder)
# =============================================================================
#
# Terminal 1 — API:
#   $env:DATABASE_URL = "<your-postgres-url>"
#   $env:PORT = "8080"
#   pnpm --filter @workspace/api-server run start
#
# Terminal 2 — frontend:
#   $env:PORT = "5173"
#   $env:BASE_PATH = "/"
#   pnpm --filter @workspace/vendi run dev
#
# Optional Cloudinary (same terminal as frontend, before `run dev`):
#   $env:VITE_CLOUDINARY_CLOUD_NAME = "your-cloud-name"
#   $env:VITE_CLOUDINARY_UPLOAD_PRESET = "your-unsigned-preset"
#
# Drizzle schema push (from `lib/db`, DATABASE_URL required):
#   $env:DATABASE_URL = "<same-as-api>"
#   pnpm run push
#
# =============================================================================
