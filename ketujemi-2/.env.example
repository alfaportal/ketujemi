# =============================================================================
# KetuJemi / Vendi — environment variables reference
#
# This repo does not load a single root `.env` for all packages. Set variables
# in your shell (see PowerShell examples at the bottom) or use a local `.env`
# where a tool supports it (e.g. Vite loads `VITE_*` from `artifacts/vendi`).
#
# IMPORTANT: The API and Vite both read `PORT` but must use different values
# on two separate terminals.
# =============================================================================

# --- Shared (API + Drizzle) ---
# Required. Used by @workspace/db and drizzle-kit (`lib/db`).
DATABASE_URL=

# --- API server (`artifacts/api-server`) ---
# Required at runtime (preferred over PORT on Windows).
API_PORT=8080

# Production single-port deploy: API serves Vite build from this folder.
# STATIC_ROOT=artifacts/vendi/dist/public

# Public site URL (auth email links). Set to your live domain in production.
# PUBLIC_APP_ORIGIN=https://your-app.example.com

# Optional. Default: info
# LOG_LEVEL=info

# --- Vite app (`artifacts/vendi`) ---
# Required for `pnpm run dev` (preferred over PORT on Windows).
WEB_PORT=5173
# Required. Use "/" for local dev.
# BASE_PATH=/

# Optional — dev proxy: browser calls /api → this backend (default http://127.0.0.1:8080)
# API_PROXY_TARGET=http://127.0.0.1:8080

# --- Auth (`artifacts/api-server`) — Vonage Verify + signed session cookie ---
SESSION_SECRET=
VONAGE_API_KEY=
VONAGE_API_SECRET=
# VITE_CLOUDINARY_CLOUD_NAME=
# VITE_CLOUDINARY_UPLOAD_PRESET=

# --- Usually unset on local Windows ---
# NODE_ENV    — set by tooling (development / production)
# REPL_ID     — set on Replit only; enables Replit-specific Vite plugins

# =============================================================================
# PowerShell examples (after `pnpm install` in this folder)
# =============================================================================
#
# Terminal 1 — API:
#   $env:DATABASE_URL = "<your-postgres-url>"
#   $env:PORT = "8080"
#   pnpm --filter @workspace/api-server run start
#
# Terminal 2 — frontend:
#   $env:PORT = "5173"
#   $env:BASE_PATH = "/"
#   pnpm --filter @workspace/vendi run dev
#
# Optional Cloudinary (same terminal as frontend, before `run dev`):
#   $env:VITE_CLOUDINARY_CLOUD_NAME = "your-cloud-name"
#   $env:VITE_CLOUDINARY_UPLOAD_PRESET = "your-unsigned-preset"
#
# Drizzle schema push (from `lib/db`, DATABASE_URL required):
#   $env:DATABASE_URL = "<same-as-api>"
#   pnpm run push
#
# =============================================================================
