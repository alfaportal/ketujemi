# =============================================================================
# KetuJemi / Vendi — environment variables reference
#
# This repo does not load a single root `.env` for all packages. Set variables
# in your shell (see PowerShell examples at the bottom) or use a local `.env`
# where a tool supports it (e.g. Vite loads `VITE_*` from `artifacts/vendi`).
#
# IMPORTANT: The API and Vite both read `PORT` but must use different values
# on two separate terminals.
# =============================================================================

# --- Shared (API + Drizzle) ---
# Required. Used by @workspace/db and drizzle-kit (`lib/db`).
# Neon pooled URL — use ?sslmode=require only on Railway (no &channel_binding; ampersand breaks some hosts).
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.pooler.region.aws.neon.tech/neondb?sslmode=require"
DATABASE_URL=

# --- API server (`artifacts/api-server`) ---
# Required at runtime (preferred over PORT on Windows).
API_PORT=8080

# Production single-port deploy: API serves Vite build from this folder.
# STATIC_ROOT=artifacts/vendi/dist/public

# Public site URL (auth email links, Stripe return URLs). Set to your live domain in production.
# PUBLIC_APP_ORIGIN=https://your-app.example.com

# --- Phase 2 (TOP €1 checkout, public payments when traffic grows) ---
# FEATURE_PHASE_2=false

# --- Stripe Checkout (VIP, TOP, portofol €5/€10/€20, njoftim shtesë) ---
# Wallet: €0.30 per paid listing; top-ups €5 (16), €10 (33), €20 (66 listings)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...
# Same key for Vite build (optional if API serves /api/config/public):
# VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe Dashboard → Developers → Webhooks → Add endpoint:
#   URL: https://ketujemi.com/api/payments/webhook  (or your Railway/Vercel domain)
#   Events: checkout.session.completed
# After deploy, run SQL migrations if not applied:
#   lib/db/sql/business-payments-migration.sql
#   lib/db/sql/partners-payment-automation-migration.sql
#   lib/db/sql/listing-package-purchases-migration.sql
#   lib/db/sql/wallet-migration.sql
#   lib/db/sql/fiscal-receipts-migration.sql
#   lib/db/sql/phone-verify-challenges-migration.sql
# Dev only: auto-mark checkout as paid when Stripe is not configured (non-production)
# PAYMENT_DEV_BYPASS=true

# --- Kosovo fiscal (wallet top-up → kupon fiskal / faturë) ---
# Off by default until Enternet/SEF API is configured. Wallet still credits when false.
# FISCAL_KOSOVO_ENABLED=false
# FISCAL_KOSOVO_PROVIDER=placeholder
# FISCAL_KOSOVO_API_URL=
# FISCAL_KOSOVO_API_KEY=
# FISCAL_LEGAL_NAME=REVOLUTION INVEST Sh.p.k.
# FISCAL_NRB=811314567
# FISCAL_CITY=Ferizaj
# FISCAL_VAT_PERCENT=18

# Optional. Default: info
# LOG_LEVEL=info

# --- Vite app (`artifacts/vendi`) ---
# Required for `pnpm run dev` (preferred over PORT on Windows).
WEB_PORT=5173
# Required. Use "/" for local dev.
# BASE_PATH=/

# Optional — dev proxy: browser calls /api → this backend (default http://127.0.0.1:8080)
# API_PROXY_TARGET=http://127.0.0.1:8080

# --- Transactional email (contact form + listing expiry reminders 3d/1d) ---
# Listing reminders: sq (383/355), mk (389), me (382) — requires verified user email.
# Inbox for contact form submissions (default: info@ketujemi.com)
# CONTACT_INBOX=info@ketujemi.com
# Railway: set EMAIL_USER + EMAIL_PASS (app password for SMTP)
EMAIL_USER=
EMAIL_PASS=
# Optional SMTP (defaults: smtp.gmail.com:587)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# EMAIL_FROM=KetuJemi <info@ketujemi.com>
# Email sign-up verification via Resend (on by default). Set false for instant sign-up without code.
# EMAIL_VERIFICATION_REQUIRED=true
RESEND_API_KEY=
# EMAIL_FROM=KetuJemi <noreply@ketujemi.com>

# --- Google reCAPTCHA v2 (SMS «Nuk jam robot») ---
# Create keys: https://www.google.com/recaptcha/admin (reCAPTCHA v2 → "I'm not a robot")
# Site key → Railway Variables (used at Vite build AND runtime via /api/config/public)
# VITE_RECAPTCHA_SITE_KEY=
# Secret key → API only (required to enforce captcha on POST /auth/sms/start)
# RECAPTCHA_SECRET_KEY=

# --- Auth (`artifacts/api-server`) — Vonage Verify + signed session cookie ---
SESSION_SECRET=
# Phone sign-up/login (Vonage Verify). Default off — use email only until SMS works.
# SMS_AUTH_ENABLED=false
# VONAGE_API_KEY=
# VONAGE_API_SECRET=
# Sender ID for transactional SMS (listing package activation, etc.)
# VONAGE_SMS_FROM=KetuJemi
# SMS anti-abuse (defaults shown)
# SMS only for +383/+355/+389/+382 unless SMS_ALLOW_INTERNATIONAL=true
# SMS_COOLDOWN_SECONDS=60
# SMS_MAX_PER_PHONE_DAY=3
# SMS_MAX_PER_IP_HOUR=5
# SMS_MAX_PER_IP_DAY=15

# --- Listing post: pause between posts for the same account (double-click / accidental repeats) ---
# LISTING_POST_USER_COOLDOWN_SECONDS=30
# Legacy alias (still read if USER var is unset): LISTING_POST_IP_COOLDOWN_SECONDS=30

# --- Backblaze B2 — foto njoftimesh (API kompatibl me S3). Nëse janë të gjitha të vendosura, përdoret B2 në vend të Cloudinary.
# Bucket: aktivizo leximin publik për skedarët (ose përdor CDN). CORS: lejo PUT nga origjina e faqes (dev + prod).
# Endpoint & rajon nga Backblaze → Bucket → «S3 Compatible API»
# B2_S3_ENDPOINT=https://s3.eu-central-003.backblazeb2.com
# B2_S3_REGION=eu-central-003
# B2_APPLICATION_KEY_ID=
# B2_APPLICATION_KEY=
# B2_BUCKET_NAME=
# URL bazë për shikim publik (shembull «Friendly URL» në konsolën B2): pa slash në fund
# B2_PUBLIC_URL_BASE=https://f005.backblazeb2.com/file/emri-i-bucket-it
# Opsionale — parashtesë për çelësat e objekteve:
# B2_KEY_PREFIX=listings

# --- Owner-only admin panel (`/admin` or `/admin-secret-panel`) — never commit real values ---
ADMIN_PANEL_PASSWORD=
ADMIN_PANEL_TOKEN=
# Support chatbot — display phone when users ask (e.g. +383 44 123 456)
# SUPPORT_PHONE=+383 44 900 100

# Vercel cron (/api/cron/jobs) — set in Vercel dashboard; Vercel sends Authorization: Bearer <value>
# CRON_SECRET=generate-a-long-random-string

# Claude AI — moderation, posting assistant, recommendations, support chat (Railway Variables)
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-5
# Optional: Railway CLI token for `pnpm run railway:env:vonage` (never commit a real token)
# RAILWAY_TOKEN=
# Cloudinary unsigned upload — përdoret vetëm nëse B2 nuk është konfiguruar plotësisht.
# VITE_CLOUDINARY_CLOUD_NAME=ddwebeeek
# VITE_CLOUDINARY_UPLOAD_PRESET=ketujemi_upload

# --- Usually unset on local Windows ---
# NODE_ENV    — set by tooling (development / production)
# REPL_ID     — set on Replit only; enables Replit-specific Vite plugins

# =============================================================================
# PowerShell examples (after `pnpm install` in this folder)
# =============================================================================
#
# Terminal 1 — API:
#   $env:DATABASE_URL = "<your-postgres-url>"
#   $env:PORT = "8080"
#   pnpm --filter @workspace/api-server run start
#
# Terminal 2 — frontend:
#   $env:PORT = "5173"
#   $env:BASE_PATH = "/"
#   pnpm --filter @workspace/vendi run dev
#
# Optional Cloudinary (same terminal as frontend, before `run dev`):
#   $env:VITE_CLOUDINARY_CLOUD_NAME = "your-cloud-name"
#   $env:VITE_CLOUDINARY_UPLOAD_PRESET = "your-unsigned-preset"
#
# Drizzle schema push (from `lib/db`, DATABASE_URL required):
#   $env:DATABASE_URL = "<same-as-api>"
#   pnpm run push
#
# =============================================================================
