{
  "name": "@workspace/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "build": "tsc --build -p tsconfig.json",
    "push": "drizzle-kit push --config ./drizzle.config.ts",
    "push-force": "drizzle-kit push --force --config ./drizzle.config.ts",
    "introspect": "drizzle-kit introspect --config ./drizzle.introspect.config.ts",
    "seed": "tsx ./src/seed.ts",
    "seed:parents": "tsx ./src/seed.ts --parents-only",
    "seed:brands": "tsx ./src/seed.ts --brands-only",
    "seed:motorr-subcats": "tsx ./src/seed.ts --motorr-subcats-only",
    "seed:auto-pjes-subcats": "tsx ./src/seed.ts --auto-pjes-subcats-only",
    "seed:banesa-subcats": "tsx ./src/seed.ts --banesa-subcats-only",
    "seed:kamione-subcats": "tsx ./src/seed.ts --kamione-subcats-only",
    "seed:general-subcats": "tsx ./src/seed.ts --general-subcats-only",
    "seed:category-images": "tsx ./src/apply-category-images.ts",
    "seed:parent-images": "tsx ./src/apply-parent-category-images.ts",
    "seed:car-models": "tsx ./src/seed-car-models.ts",
    "seed:truck-models": "tsx ./src/seed-truck-models.ts",
    "seed:motor-models": "tsx ./src/seed-motor-models.ts",
    "sql:run": "tsx ./src/run-sql-file.ts"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "drizzle-orm": "catalog:",
    "drizzle-zod": "^0.8.3",
    "pg": "^8.20.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.9",
    "tsx": "catalog:"
  }
}
