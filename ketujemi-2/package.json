{
  "name": "workspace",
  "version": "0.0.0",
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.12.1"
  },
  "license": "MIT",
  "scripts": {
    "preinstall": "node ./scripts/check-pnpm.mjs",
    "dev": "node ./scripts/dev-all.mjs",
    "dev:api": "pnpm --filter @workspace/api-server run dev",
    "dev:web": "pnpm --filter @workspace/vendi run dev",
    "db:push": "pnpm --filter @workspace/db run push",
    "db:seed:parent-images": "pnpm --filter @workspace/db run seed:parent-images",
    "db:seed": "pnpm --filter @workspace/db run seed",
    "build:production": "node ./scripts/build-production.mjs",
    "start": "node ./scripts/start-production.mjs",
    "start:production": "node ./scripts/start-production.mjs",
    "railway:env:vonage": "node ./scripts/railway-set-vonage-env.mjs",
    "railway:env:facebook": "node ./scripts/railway-set-facebook-env.mjs",
    "railway:env:database-url": "node ./scripts/railway-set-database-url.mjs",
    "railway:env:resend": "node ./scripts/railway-set-resend-env.mjs",
    "railway:env:payments": "node ./scripts/railway-set-payment-env.mjs",
    "railway:migrate:wallet": "node ./scripts/railway-wallet-migration.mjs",
    "run:facebook-scheduled-post": "pnpm --filter @workspace/api-server run run:facebook-scheduled-post",
    "run:social-scheduled-posts": "pnpm --filter @workspace/api-server run run:social-scheduled-posts",
    "run:social-scheduled-posts:railway": "node ./scripts/run-social-posts-railway.mjs",
    "run:listing-reel": "pnpm --filter @workspace/api-server run run:listing-reel",
    "build": "node ./scripts/build-production.mjs",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "@esbuild/win32-x64": "0.27.3",
    "@rollup/rollup-win32-x64-msvc": "4.59.0",
    "@tailwindcss/oxide-win32-x64-msvc": "4.2.1",
    "lightningcss-win32-x64-msvc": "^1.32.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.59.0",
    "@tailwindcss/oxide-linux-x64-gnu": "4.2.1",
    "lightningcss-linux-x64-gnu": "^1.31.1"
  }
}
